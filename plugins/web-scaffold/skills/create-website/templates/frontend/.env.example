# Public site URL (must include scheme, no trailing slash)
NEXT_PUBLIC_SITE_URL=https://{{domain}}

# Backend API base URL
NEXT_PUBLIC_API_BASE_URL=https://{{api_domain}}

# Server-only: contact form email delivery via Resend (https://resend.com)
# Leave unset to disable sending; the contact endpoint will still accept POSTs locally.
RESEND_API_KEY=
CONTACT_INBOX_EMAIL={{contact_email}}
RESEND_FROM_EMAIL=

# Analytics (optional). Provider: "plausible" | "posthog" | "none".
NEXT_PUBLIC_ANALYTICS_PROVIDER=none
NEXT_PUBLIC_PLAUSIBLE_DOMAIN={{domain}}
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
