APP_ENV=development
CORS_ORIGINS=http://localhost:3000,https://{{domain}},https://www.{{domain}}
CONTACT_INBOX_EMAIL={{contact_email}}

# Optional: enable outbound email via Resend (https://resend.com)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Rate-limit for /contact (requests per window per client IP)
CONTACT_RATE_LIMIT=5/minute
